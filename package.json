{
  "name": "openmagnetics-web-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Web frontend for openmagnetics.com — free, open-source magnetics design: advisers, converter wizards, simulation and export, powered by the MKF C++ engine compiled to WebAssembly.",
  "license": "MIT",
  "author": "OpenMagnetics",
  "homepage": "https://openmagnetics.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenMagnetics/WebFrontend.git"
  },
  "bugs": {
    "url": "https://github.com/OpenMagnetics/WebFrontend/issues"
  },
  "keywords": [
    "magnetics",
    "transformer",
    "inductor",
    "power-electronics",
    "magnetic-design",
    "webassembly",
    "vue"
  ],
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "node --max-old-space-size=4096 node_modules/.bin/vite build",
    "preview": "vite preview",
    "build:css": "sass --load-path=node_modules --quiet --quiet-deps src/assets/scss:src/assets/css",
    "test:coverage": "COVERAGE=1 playwright test",
    "test:lint": "node tests/lint-tests.js",
    "test:lint:ci": "node tests/lint-tests.js --mode=error"
  },
  "dependencies": {
    "@chenfengyuan/vue-number-input": "^2.0.1",
    "@popperjs/core": "^2.11.8",
    "@primeuix/themes": "^2.0.3",
    "@vueform/slider": "^2.1.10",
    "@vuepic/vue-datepicker": "^12.0.5",
    "@vueuse/core": "^14.0.0",
    "axios": "^1.16.1",
    "bootstrap-icons": "^1.13.1",
    "chartjs-plugin-dragdata": "^2.3.1",
    "comlink": "^4.4.2",
    "cors": "^2.8.5",
    "datatables.net-vue3": "^3.0.4",
    "driver.js": "^1.6.0",
    "echarts": "^6.0.0",
    "katex": "^0.16.21",
    "mathjs": "^15.1.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "process": "^0.11.10",
    "three": "^0.181.2",
    "three-trackballcontrols": "^0.9.0",
    "troisjs": "^0.3.4",
    "vatex": "^0.1.0",
    "vue": "^3.5.24",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.3",
    "vue-window-size": "^2.0.0",
    "vue3-cookies": "^1.0.6",
    "vue3-popper": "^1.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "monocart-reporter": "^2.10.1",
    "raw-loader": "^4.0.2",
    "sass": "^1.94.1",
    "vite": "^7.2.2",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-static-copy": "^3.2.0"
  },
  "overrides": {
    "katex": "^0.16.21"
  }
}
